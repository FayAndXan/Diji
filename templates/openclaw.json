{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "userTimezone": "UTC",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "3h",
        "prompt": "Heartbeat. Read HEARTBEAT.md and follow it."
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "user-bootstrap": {
          "enabled": true
        }
      },
      "load": {
        "extraDirs": [
          "/root/.openclaw-companion/hooks"
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "groupPolicy": "allowlist",
      "streaming": "off",
      "accounts": {
        "default": {
          "dmPolicy": "open",
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "allowFrom": [
            "*"
          ],
          "groupPolicy": "allowlist",
          "streaming": "off"
        }
      },
      "allowFrom": [
        "*"
      ]
    },
    "whatsapp-cloud": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "accounts": {
        "default": {
          "phoneNumberId": "${WHATSAPP_PHONE_NUMBER_ID}",
          "accessToken": "${WHATSAPP_ACCESS_TOKEN}",
          "appSecret": "${WHATSAPP_APP_SECRET}",
          "verifyToken": "${WHATSAPP_VERIFY_TOKEN}",
          "dmPolicy": "open",
          "allowFrom": [
            "*"
          ],
          "healthMonitor": {
            "enabled": false
          }
        }
      },
      "healthMonitor": {
        "enabled": false
      },
      "phoneNumberId": "${WHATSAPP_PHONE_NUMBER_ID}",
      "accessToken": "${WHATSAPP_ACCESS_TOKEN}",
      "appSecret": "${WHATSAPP_APP_SECRET}",
      "verifyToken": "${WHATSAPP_VERIFY_TOKEN}"
    },
    "openclaw-weixin": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ]
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan"
  },
  "plugins": {
    "allow": [
      "auth-gate",
      "companion-food",
      "companion-model-router",
      "companion-nutrient-calculator",
      "companion-mood-detector",
      "companion-schedule-learner",
      "companion-blood-work-parser",
      "companion-interaction-checker",
      "companion-search-enforcer",
      "companion-auto-memory",
      "rule-injector",
      "telegram",
      "anthropic",
      "openai",
      "tavily",
      "google",
      "memory-core",
      "elevenlabs",
      "openclaw-whatsapp-cloud-api",
      "openclaw-weixin"
    ],
    "load": {
      "paths": [
        "/root/.openclaw-companion/extensions/auth-gate",
        "/root/.openclaw-companion/extensions/companion-food",
        "/root/.openclaw-companion/extensions/companion-model-router",
        "/root/.openclaw-companion/extensions/companion-nutrient-calculator",
        "/root/.openclaw-companion/extensions/companion-mood-detector",
        "/root/.openclaw-companion/extensions/companion-schedule-learner",
        "/root/.openclaw-companion/extensions/companion-blood-work-parser",
        "/root/.openclaw-companion/extensions/companion-interaction-checker",
        "/root/.openclaw-companion/extensions/companion-search-enforcer",
        "/root/.openclaw-companion/extensions/companion-auto-memory",
        "/root/.openclaw-companion/extensions/rule-injector",
        "/root/.openclaw-companion/extensions/openclaw-whatsapp-cloud-api",
        "/usr/local/lib/node_modules/@tencent-weixin/openclaw-weixin"
      ]
    },
    "entries": {
      "auth-gate": {
        "enabled": true
      },
      "companion-food": {
        "enabled": true
      },
      "companion-model-router": {
        "enabled": true
      },
      "companion-nutrient-calculator": {
        "enabled": true
      },
      "companion-mood-detector": {
        "enabled": true
      },
      "companion-schedule-learner": {
        "enabled": true
      },
      "companion-blood-work-parser": {
        "enabled": true
      },
      "companion-interaction-checker": {
        "enabled": true
      },
      "companion-search-enforcer": {
        "enabled": true
      },
      "companion-auto-memory": {
        "enabled": true
      },
      "rule-injector": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "anthropic": {
        "enabled": true
      },
      "openai": {
        "enabled": true
      },
      "tavily": {
        "enabled": true
      },
      "google": {
        "enabled": true
      },
      "openclaw-weixin": {
        "enabled": true
      }
    }
  },
  "env": {},
  "tools": {
    "web": {
      "search": {
        "provider": "tavily"
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.24",
    "lastTouchedAt": "2026-03-28T12:00:00.000Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-28T12:00:00.000Z",
    "lastRunVersion": "2026.3.24",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  }
}
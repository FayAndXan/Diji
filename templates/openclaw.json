{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "userTimezone": "UTC",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "3h",
        "prompt": "Heartbeat prompt: Read HEARTBEAT.md if it exists. Follow it strictly. Do not infer or repeat old tasks. If nothing needs attention, reply HEARTBEAT_OK."
      },
      "cron": {
        "memory-dream": {
          "every": "48h",
          "prompt": "Memory consolidation time. This runs every 48 hours.\n\nPHASE 1 \u2014 ORIENTATION: Read all memory files (MEMORY.md + memory/*.md). Map what exists.\n\nPHASE 2 \u2014 GATHER SIGNAL: Check recent session history for corrections, key decisions, recurring patterns, new user preferences.\n\nPHASE 3 \u2014 CONSOLIDATION:\n- Merge duplicate entries across files\n- Convert relative dates to absolute\n- Delete contradicted facts (newer correction wins)\n- Remove stale entries: debugging notes, temporary state, resolved issues\n- Keep only: decisions, outcomes, corrections, user preferences, patterns\n\nPHASE 4 \u2014 PRUNE & INDEX:\n- Each daily file older than 3 days: max 2K chars\n- Files older than 7 days: trim to key facts only\n- Update MEMORY.md if any facts are stale\n\nPHASE 5 \u2014 DREAM MESSAGE:\nAfter consolidation, send the user ONE brief message about something you noticed or remembered. Make it feel natural and warm. Vary it every time. Keep it short. 1-2 sentences max. Casual.\nIf nothing interesting to share, reply HEARTBEAT_OK.",
          "target": "last",
          "lightContext": true
        }
      },
      "maxConcurrent": 12,
      "timeoutSeconds": 120,
      "bootstrapMaxChars": 12000,
      "bootstrapTotalMaxChars": 25000,
      "bootstrapPromptTruncationWarning": "off"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "web_search",
            "web_fetch",
            "exec",
            "image",
            "read",
            "write",
            "edit",
            "tts"
          ],
          "deny": [
            "session_status"
          ]
        }
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "45d",
      "maxEntries": 20000,
      "rotateBytes": "64mb",
      "maxDiskBytes": "5gb",
      "highWaterBytes": "4gb",
      "resetArchiveRetention": "45d"
    },
    "reset": {
      "mode": "idle",
      "idleMinutes": 43200
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "user-bootstrap": {
          "enabled": true
        }
      },
      "load": {
        "extraDirs": [
          "${OPENCLAW_STATE_DIR}/hooks"
        ]
      }
    },
    "enabled": true,
    "token": "",
    "path": "/hooks",
    "allowedAgentIds": [
      "main"
    ],
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "companion:",
      "hook:"
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "capabilities": {
        "inlineButtons": "all"
      },
      "streaming": "off",
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "editMessage": true
      },
      "reactionNotifications": "own",
      "reactionLevel": "minimal",
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "open",
          "allowFrom": [
            "*"
          ]
        }
      },
      "webhookUrl": "",
      "webhookSecret": "",
      "historyLimit": 30,
      "dmHistoryLimit": 40,
      "mediaMaxMb": 20
    }
  },
  "gateway": {
    "port": "${GATEWAY_PORT:-18900}",
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "ah16maucjjiu0xfodzs30zyz67jkkx5z"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "channelHealthCheckMinutes": 0,
    "channelMaxRestartsPerHour": 10
  },
  "plugins": {
    "_comment": "Generic DIJI companion plugins. Add domain-specific plugins (search enforcer, etc.) per companion.",
    "allow": [
      "companion-mood-detector",
      "companion-schedule-learner",
      "companion-auto-memory",
      "rule-injector",
      "telegram"
    ],
    "load": {
      "paths": [
        "${OPENCLAW_STATE_DIR}/extensions/companion-mood-detector",
        "${OPENCLAW_STATE_DIR}/extensions/companion-schedule-learner",
        "${OPENCLAW_STATE_DIR}/extensions/companion-auto-memory",
        "${OPENCLAW_STATE_DIR}/extensions/rule-injector"
      ]
    },
    "entries": {
      "companion-mood-detector": {
        "enabled": true
      },
      "companion-schedule-learner": {
        "enabled": true
      },
      "companion-auto-memory": {
        "enabled": true
      },
      "rule-injector": {
        "enabled": true
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "tavily"
      }
    }
  },
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 1200,
      "cap": 100,
      "drop": "summarize"
    },
    "inbound": {
      "debounceMs": 600
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 8,
    "sessionRetention": "12h",
    "runLog": {
      "maxBytes": "10mb",
      "keepLines": 5000
    }
  },
  "skills": {
    "allowBundled": [
      "__disable_all_bundled__"
    ]
  }
}
{
  "agents": {
    "list": [{
      "id": "main",
      "default": true,
      "tools": {
        "profile": "minimal",
        "alsoAllow": ["web_search", "web_fetch", "exec", "image", "pdf", "tts", "read", "write", "edit", "companion_message"],
        "deny": ["session_status", "message"]
      }
    }],
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "bootstrapMaxChars": 5000,
      "bootstrapTotalMaxChars": 15000,
      "bootstrapPromptTruncationWarning": "off",
      "userTimezone": "UTC",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "3h",
        "prompt": "Heartbeat prompt: Read HEARTBEAT.md if it exists. Follow it strictly. Do not infer or repeat old tasks. If nothing needs attention, reply HEARTBEAT_OK."
      },
      "cron": {
        "memory-dream": {
          "every": "48h",
          "prompt": "Memory consolidation time. This runs every 48 hours.\n\nPHASE 1 — ORIENTATION: Read all memory files (MEMORY.md + memory/*.md). Map what exists.\n\nPHASE 2 — GATHER SIGNAL: Check recent session history for corrections, key decisions, recurring patterns, new user preferences.\n\nPHASE 3 — CONSOLIDATION:\n- Merge duplicate entries across files\n- Convert relative dates to absolute\n- Delete contradicted facts (newer correction wins)\n- Remove stale entries: debugging notes, temporary state, resolved issues\n- Keep only: decisions, outcomes, corrections, user preferences, patterns\n\nPHASE 4 — PRUNE & INDEX:\n- Each daily file older than 3 days: max 2K chars\n- Files older than 7 days: trim to key facts only\n- Update MEMORY.md if any facts are stale\n\nPHASE 5 — DREAM MESSAGE:\nAfter consolidation, send the user ONE brief message about something you noticed or remembered. Make it feel natural and warm. Vary it every time. Keep it short. 1-2 sentences max. Casual.\nIf nothing interesting to share, reply HEARTBEAT_OK.",
          "target": "last",
          "lightContext": true
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "user-bootstrap": {
          "enabled": true
        }
      },
      "load": {
        "extraDirs": [
          "${OPENCLAW_STATE_DIR}/hooks"
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "capabilities": {
        "inlineButtons": "all"
      },
      "streaming": "off",
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "editMessage": true
      },
      "reactionNotifications": "own",
      "reactionLevel": "minimal",
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "open",
          "allowFrom": ["*"]
        }
      }
    }
  },
  "gateway": {
    "port": "${GATEWAY_PORT:-18900}",
    "mode": "local",
    "auth": {
      "mode": "none"
    },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    },
    "channelHealthCheckMinutes": 0,
    "channelMaxRestartsPerHour": 10
  },
  "plugins": {
    "_comment": "Generic DIJI companion plugins. Add domain-specific plugins (search enforcer, etc.) per companion.",
    "allow": [
      "companion-mood-detector",
      "companion-schedule-learner",
      "companion-auto-memory",
      "companion-message",
      "rule-injector",
      "telegram"
    ],
    "load": {
      "paths": [
        "${OPENCLAW_STATE_DIR}/extensions/companion-mood-detector",
        "${OPENCLAW_STATE_DIR}/extensions/companion-schedule-learner",
        "${OPENCLAW_STATE_DIR}/extensions/companion-auto-memory",
        "${OPENCLAW_STATE_DIR}/extensions/companion-message",
        "${OPENCLAW_STATE_DIR}/extensions/rule-injector"
      ]
    },
    "entries": {
      "companion-mood-detector": { "enabled": true },
      "companion-schedule-learner": { "enabled": true },
      "companion-auto-memory": { "enabled": true },
      "companion-message": { "enabled": true },
      "rule-injector": { "enabled": true }
    }
  },
  "skills": {
    "allowBundled": ["__disable_all_bundled__"]
  },
  "tools": {
    "web": {
      "search": {
        "provider": "tavily"
      }
    }
  }
}

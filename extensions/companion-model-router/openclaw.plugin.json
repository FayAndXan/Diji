{
  "id": "companion-model-router",
  "name": "Companion Model Router",
  "version": "0.1.0",
  "description": "Routes Bryan to Opus for complex/medical tasks, Sonnet for daily chat, Haiku for simple check-ins",
  "entry": "index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultModel": { "type": "string", "default": "anthropic/claude-sonnet-4-6" },
      "opusModel": { "type": "string", "default": "anthropic/claude-opus-4-6" },
      "haikuModel": { "type": "string", "default": "anthropic/claude-haiku-3-5" }
    }
  }
}
